# Flask
SECRET_KEY=replace-with-long-random-secret

# Login
AUTH_USERNAME=admin
# Either set plain password OR hash.
AUTH_PASSWORD=replace-with-strong-password
# AUTH_PASSWORD_HASH=pbkdf2:sha256:...

# Database
# Local SQLite example:
# DATABASE_URL=sqlite:///instance/holdings.db
# Render/Supabase/Neon Postgres example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional
PRICE_PROVIDER=yfinance
